#!/usr/bin/env bash
# setup — Install ralph-skills into Claude Code
# Creates symlinks so each skill is discoverable as a slash command.
#
# Usage: ./setup
#   Run from the ralph-skills directory after cloning.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$(dirname "$SCRIPT_DIR")"
REPO_NAME="$(basename "$SCRIPT_DIR")"

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo " ralph-skills setup"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Guard: only create symlinks if we're inside a skills/ directory
if [ "$(basename "$SKILLS_DIR")" != "skills" ]; then
  echo "⚠  Not inside a skills/ directory — skipping symlinks."
  echo "   Expected: ~/.claude/skills/ralph-skills/ or .claude/skills/ralph-skills/"
  echo "   Got: $SCRIPT_DIR"
  exit 1
fi

# Build the set of valid skill names from current SKILL.md directories
valid_skills=()
for skill_dir in "$SCRIPT_DIR"/*/; do
  [ ! -d "$skill_dir" ] && continue
  skill_name="$(basename "$skill_dir")"
  [ ! -f "$skill_dir/SKILL.md" ] && continue
  valid_skills+=("$skill_name")
done

# Remove stale symlinks: any symlink in SKILLS_DIR that points into this repo
# but no longer corresponds to a current skill directory
for existing_link in "$SKILLS_DIR"/*/; do
  [ ! -L "${existing_link%/}" ] && continue
  link_name="$(basename "${existing_link%/}")"
  link_target="$(readlink "${existing_link%/}" 2>/dev/null || true)"

  # Only manage symlinks that point into this repo
  [[ "$link_target" != "$REPO_NAME/"* ]] && continue

  # Check if it's still a valid skill
  still_valid=false
  for s in "${valid_skills[@]}"; do
    [ "$s" = "$link_name" ] && still_valid=true && break
  done

  if [ "$still_valid" = false ]; then
    rm -f "${existing_link%/}"
    echo "✗  $link_name (removed — skill renamed or deleted)"
  fi
done

# Create/update symlinks for all current skills
for skill_name in "${valid_skills[@]}"; do
  ln -snf "$REPO_NAME/$skill_name" "$SKILLS_DIR/$skill_name"
  echo "✓  $skill_name"
done

# Make ralph-template.sh executable
if [ -f "$SCRIPT_DIR/ralph-prep/references/ralph-template.sh" ]; then
  chmod +x "$SCRIPT_DIR/ralph-prep/references/ralph-template.sh"
fi

echo ""
echo "Done. Run /context in Claude Code to verify."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
